name: Proyek_Workflow_CI_Rizal

# Menggunakan environment virtualenv/pip lokal bawaan runner
venv:
  package_manager: pip

entry_points:
  main:
    parameters:
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 10}
    command: "python modelling.py --n_estimators {n_estimators} --max_depth {max_depth}"